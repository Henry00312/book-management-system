# ==============================================
# CONFIGURACIÓN BÁSICA - SISTEMA DE GESTIÓN DE LIBROS
# ==============================================

# Entorno de ejecución
NODE_ENV=development

# Puerto del servidor
PORT=3000

# ----------------------------------------------
# BASE DE DATOS
# ----------------------------------------------

# MongoDB URI
# Para MongoDB Atlas: mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/bookstore?retryWrites=true&w=majority&appName=ClusterName
# Para MongoDB local: mongodb://localhost:27017/bookstore
MONGODB_URI=mongodb://localhost:27017/bookstore

# ----------------------------------------------
# AUTENTICACIÓN JWT
# ----------------------------------------------

# Clave secreta JWT (generar una clave segura de 64+ caracteres)
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_super_seguro_de_al_menos_64_caracteres_aqui

# Tiempo de expiración del token
JWT_EXPIRES_IN=24h

# Configuración JWT adicional
JWT_ALGORITHM=HS256
JWT_ISSUER=book-management-system
JWT_AUDIENCE=book-management-users

# ----------------------------------------------
# DESARROLLO
# ----------------------------------------------

# Auto-crear datos de prueba
DEV_AUTO_SEED=true

# Habilitar Swagger
DEV_ENABLE_SWAGGER=true
